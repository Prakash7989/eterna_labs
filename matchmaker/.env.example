# Copy this file to `.env` in this folder (matchmaker/.env)

# Option A: separate fields (recommended for local MySQL / XAMPP)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=your_mysql_password
DB_NAME=matchmaker

# Option B: single URL (Docker Compose default)
# DATABASE_URL=mysql://matchmaker:matchmaker@127.0.0.1:3306/matchmaker
# DATABASE_URL=mysql://root:root@127.0.0.1:3306/matchmaker

# API port (Vite proxy targets this)
MATCHMAKER_PORT=8081
